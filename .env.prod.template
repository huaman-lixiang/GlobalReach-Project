# GlobalReach V2.0 — Production Docker Compose Environment Template
# DEBT-007 + DEBT-008: Security Hardening — All secrets must be set via .env.prod
#
# ⚠️ USAGE:
#   1. Copy this file: cp .env.prod.template .env.prod
#   2. Fill in ALL <CHANGE_ME> values below
#   3. Ensure .env.prod is in .gitignore (NEVER commit real secrets!)
#   4. Deploy: docker compose -f docker-compose.prod.yml up -d
#
# 🔴 CRITICAL: Missing any *_PASSWORD or *_SECRET variable will cause
#    Docker Compose to FAIL at startup with an ERROR message.
#    This is intentional — prevents accidental deployment with weak/missing credentials.
#
# ─── Version Tracking ──────────────────────────────────────────────
# Template Version: S133-DEBT-007+008-v1.0
# Last Updated: DEBT-007 (SMTP hardcoded) + DEBT-008 (Grafana weak default)
# Compatible With: docker-compose.prod.yml

# ─── Database ──────────────────────────────────────────────────────
DB_NAME=globalreach_prod
DB_USER=globalreach_user
DB_PASSWORD=<CHANGE_ME_STRONG_DB_PASSWORD_MIN_16_CHARS>

# ─── API Security ──────────────────────────────────────────────────
JWT_SECRET=<CHANGE_ME_MIN_32_CHARS_RANDOM_STRING>
CSRF_SECRET=<CHANGE_ME_MIN_32_CHARS_RANDOM_STRING>
WEBHOOK_SECRET=<CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32>

# ─── Grafana Admin Password (DEBT-008) ─────────────────────────────
# 🔴 REQUIRED — Docker Compose will refuse startup if unset
# Security Policy:
#   - Minimum 20 characters
#   - MUST contain: uppercase + lowercase + digits + special characters
#   - Example: Gr@fana_Sec2026!Adm1n-Pass#Strong
#
# ⚠️ PORT SECURITY: Grafana maps container :3000 → host :3002
#   In production, restrict access via:
#     - Nginx reverse proxy with auth_basic
#     - Firewall rule: only allow internal IPs on port 3002
#     - Or bind to 127.0.0.1:3002 instead of 0.0.0.0:3002
GRAFANA_ADMIN_PASSWORD=<CHANGE_ME_GRAFANA_ADMIN_20+_CHARS_MIXED_CASE_DIGITS_SPECIAL>

# ─── SMTP Password (DEBT-007) — Shared by Grafana + AlertManager ──
# 🔴 REQUIRED — Used by BOTH grafana and alertmanager services
# This is the SMTP auth credential (e.g., QQ Mail 授权码 / App Password)
# NEVER commit the real value to version control!
GF_SMTP_PASSWORD=<CHANGE_ME_SMTP_AUTH_PASSWORD_OR_AUTH_CODE>

# ─── AlertManager Notification Routing ─────────────────────────────
ALERTMANAGER_SMTP_SMARTHOST=smtp.qq.com:465
ALERTMANAGER_SMTP_USER=1390885333@qq.com
ALERTMANAGER_SMTP_PASS=${GF_SMTP_PASSWORD}
ALERTMANAGER_SMTP_FROM=1390885333@qq.com
ALERTMANAGER_EMAIL_TO=admin@globalreach.com
ALERTMANAGER_SMTP_REQUIRE_TLS=true
ALERTMANAGER_SMTP_HELLO=qq.com
ALERTMANAGER_WEBHOOK_URL=

# ─── Grafana Alerting ──────────────────────────────────────────────
GRAFANA_ALERT_EMAIL_TO=admin@globalreach.com
GRAFANA_ALERT_WEBHOOK_URL=

# ─── API Server ────────────────────────────────────────────────────
API_PORT=3000
IMAGE_TAG=latest
RATE_LIMIT_MAX=30000
RATE_LIMIT_WINDOW_MS=900000
SEND_CONCURRENCY=5
SEND_MAX_RETRIES=3
SEND_RETRY_DELAY=1000
SEND_RATE_LIMIT=3

# ─── SSL / Let's Encrypt ──────────────────────────────────────────
LETSENCRYPT_EMAIL=admin@globalreach.com
CERTBOT_DOMAINS=api.globalreach.com,app.globalreach.com,monitor.globalreach.com,grafana.globalreach.com
