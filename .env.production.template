# GlobalReach V2.0 — Production Environment Configuration
# S114/PhaseI: Production Readiness — All values tuned and verified
#
# ⚠️ USAGE: Copy this file to .env.production and replace <CHANGE_ME> values
#    cp .env.production.template .env.production
#    # Edit all <CHANGE_ME> placeholders before deploying!
#
# ─── Version Tracking ──────────────────────────────────────────────
# Template Version: S114-Production-v1.0
# Last Updated: S114 (Phase I Closeout)
# Compatible With: docker-compose.prod.yml (commit e26e917)

# ─── Application ───────────────────────────────────────────────────
NODE_ENV=production
APP_NAME=GlobalReach-V2
APP_VERSION=2.0.0
APP_URL=https://api.globalreach.com

# ─── Server ────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ─── Security (MUST CHANGE BEFORE PRODUCTION!) ─────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=<CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32>
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ─── Database (PostgreSQL) ────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=globalreach_prod
DB_USER=globalreach_user
DB_PASSWORD=<CHANGE_ME_STRONG_DB_PASSWORD_MIN_16_CHARS>
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_ACQUIRE_TIMEOUT=30000
DB_IDLE_TIMEOUT=10000

# Prisma ORM URL
DATABASE_URL="postgresql://globalreach_user:<CHANGE_ME_SAME_AS_DB_PASSWORD>@postgres:5432/globalreach_prod?schema=public"

# ─── Redis Cache ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<CHANGE_ME_REDIS_PASSWORD_OR_LEAVE_EMPTY>
REDIS_DB=0
REDIS_TTL=3600

# ─── CORS (update with your actual domain) ─────────────────────────
CORS_ORIGIN=https://app.globalreach.com,https://monitor.globalreach.com,https://api.globalreach.com

# ─── Rate Limiting (S112 Tuned Values) ─────────────────────────────
# L2 Express rate limiter: 30000 requests / 15min window = ~33 rps per IP
# Override via: RATE_LIMIT_MAX / RATE_LIMIT_WINDOW_MS env vars
RATE_LIMIT_MAX=30000
RATE_LIMIT_WINDOW_MS=900000

# API Key rate limit (for authenticated endpoints)
RATE_LIMIT_API_KEY_MAX_REQUESTS=1000
RATE_LIMIT_API_KEY_WINDOW_MS=60000

# Auth endpoint rate limit (strict — prevents brute force)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Email send rate limit
EMAIL_RATE_LIMIT_MAX=20
EMAIL_RATE_LIMIT_WINDOW_MS=60000

# Batch operation rate limit
BATCH_RATE_LIMIT_MAX=5
BATCH_RATE_LIMIT_WINDOW_MS=300000

# ─── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── File Upload ──────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/app/uploads

# ─── Email Service (SMTP) — S116: Production SMTP Migration ──────
# See SMTP_MIGRATION_GUIDE.md for complete provider setup instructions
#
# STEP 1: Choose ONE provider below and uncomment it
# STEP 2: Fill in your credentials
# STEP 3: Also update ALERTMANAGER_* and GRAFANA_SMTP_* vars below

# --- Option A: Amazon SES (Recommended for Enterprise) ---
# Free tier: 62,000 emails/mo | Production: $0.10/1000
#SMTP_HOST=email-smtp.us-east-1.amazonaws.com
#SMTP_PORT=587
#SMTP_USER=<SES_SMTP_USERNAME_AKIAIOSFODNN7EXAMPLE>
#SMTP_PASS=<SES_SMTP_PASSWORD>
#EMAIL_FROM="GlobalReach <noreply@globalreach.com>"

# --- Option B: SendGrid (Recommended for Startups) ---
# Free tier: 100/day | Basic plan: $14.95/mo unlimited
#SMTP_HOST=smtp.sendgrid.net
#SMTP_PORT=587
#SMTP_USER=apikey
#SMTP_PASS=<SENDGRID_API_KEY_SG.xxxx>
#EMAIL_FROM="GlobalReach <noreply@globalreach.com>"

# --- Option C: Gmail SMTP (For Low Volume / Personal Use) ---
# Limit: 500/day regular, 2000/day Workspace | Requires App Password
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=<your_gmail_address@gmail.com>
#SMTP_PASS=<your_16_char_app_password>
#EMAIL_FROM="GlobalReach <your_gmail_address@gmail.com>"

# --- Option D: Resend (Developer-Friendly) ---
# Free tier: 3,000/mo | Production: $0.0025/email
#SMTP_HOST=smtp.resend.com
#SMTP_PORT=465
#SMTP_USER=resend
#SMTP_PASS=<RESEND_API_KEY_re_xxxx>
#EMAIL_FROM="GlobalReach <noreply@globalreach.com>"

# --- Default placeholder (replace with one of the options above) ---
SMTP_HOST=<CHANGE_ME_SMTP_HOST_EG_smtp_ses_amazonaws_com>
SMTP_PORT=587
SMTP_USER=<CHANGE_ME_SMTP_USERNAME>
SMTP_PASS=<CHANGE_ME_SMTP_PASSWORD>
EMAIL_FROM="GlobalReach <noreply@globalreach.com>"

# ─── Monitoring ───────────────────────────────────────────────────
ENABLE_METRICS=true
METRICS_PORT=9090

# ─── SSL/TLS (managed by certbot/Let's Encrypt) ───────────────────
SSL_CERT_PATH=/etc/nginx/ssl/letsencrypt/live/api.globalreach.com/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/letsencrypt/live/api.globalreach.com/privkey.pem

# ─── Feature Flags ─────────────────────────────────────────────────
ENABLE_REGISTRATION=false
ENABLE_EMAIL_VERIFICATION=true
MAX_ACCOUNTS_PER_USER=50
MAX_CAMPAIGNS_PER_DAY=10

# ─── Grafana Alerting (S106-S108, S116 Updated) ───────────────────
GF_SECURITY_ADMIN_PASSWORD=<CHANGE_ME_GRAFANA_ADMIN_PASSWORD>
GF_SMTP_ENABLED=true
# Grafana SMTP — set to same provider as SMTP_HOST above
GF_SMTP_HOST=${SMTP_HOST:-mailpit:1025}
GF_SMTP_USER=${SMTP_USER:-}
GF_SMTP_PASSWORD=${SMTP_PASS:-}
GF_SMTP_FROM_ADDRESS=${EMAIL_FROM:-noreply@globalreach.com}
GF_SMTP_FROM_NAME="GlobalReach Monitor"
GRAFANA_ALERT_EMAIL_TO=admin@globalreach.com
GRAFANA_ALERT_WEBHOOK_URL=

# ─── AlertManager SMTP (S116: Production Migration) ────────────────
# These override alertmanager.yml defaults. Set to match your SMTP provider.
# See SMTP_MIGRATION_GUIDE.md Part 6 for switch procedure.
ALERTMANAGER_SMTP_SMARTHOST=${SMTP_HOST:-mailpit:1025}
ALERTMANAGER_SMTP_USER=${SMTP_USER:-}
ALERTMANAGER_SMTP_PASS=${SMTP_PASS:-}
ALERTMANAGER_SMTP_FROM=${EMAIL_FROM:-alert@globalreach.local}
ALERTMANAGER_EMAIL_TO=admin@globalreach.com
ALERTMANAGER_SMTP_REQUIRE_TLS=false   # Set true for SES/SendGrid/Gmail/Resend
ALERTMANAGER_SMTP_HELLO=globalreach.com
ALERTMANAGER_WEBHOOK_URL=

# ─── Let's Encrypt (S101/S114) ────────────────────────────────────
LETSENCRYPT_EMAIL=admin@globalreach.com
