# GlobalReach V2.0 - CDN Environment Variables
# Copy this file to .env.local and fill in your values for CDN deployment
# Reference: docs/CDN_INTEGRATION_PLAN.md (M-E02)

# ============================================================================
# CDN Configuration (M-E02)
# ============================================================================
# Base URL for CDN deployment (e.g., https://cdn.example.com/globalreach/)
# Leave empty for local development (uses relative paths '/')
VITE_CDN_BASE_URL=

# Example values:
# VITE_CDN_BASE_URL=https://cdn.globalreach.com/static/
# VITE_CDN_BASE_URL=https://d1abc123.cloudfront.net/production/
