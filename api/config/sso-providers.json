{"$schema": "./sso-providers.schema.json", "_description": "GlobalReach SSO Provider 配置模板 - 复制此文件到项目根目录 .env 中填写实际值", "global": {"enabled": true, "autoProvisioning": true, "callbackBaseUrl": "${SSO_CALLBACK_BASE_URL}", "sessionSecret": "${SSO_SESSION_SECRET}", "defaultRole": "USER", "tokenExpiresIn": "15m"}, "providers": {"google": {"enabled": "${GOOGLE_CLIENT_ID:true}", "type": "oidc", "displayName": "Google", "icon": "google", "clientId": "${GOOGLE_CLIENT_ID}", "clientSecret": "${GOOGLE_CLIENT_SECRET}", "callbackURL": "${GOOGLE_CALLBACK_URL}", "scope": ["email", "profile", "openid"], "authorizationURL": "https://accounts.google.com/o/oauth2/v2/auth", "tokenURL": "https://oauth2.googleapis.com/token", "userInfoURL": "https://www.googleapis.com/oauth2/v2/userinfo", "attributeMap": {"email": "email", "name": "name", "avatar": "picture"}}, "github": {"enabled": "${GITHUB_CLIENT_ID:true}", "type": "oauth2", "displayName": "GitHub", "icon": "github", "clientId": "${GITHUB_CLIENT_ID}", "clientSecret": "${GITHUB_CLIENT_SECRET}", "callbackURL": "${GITHUB_CALLBACK_URL}", "scope": ["user:email"], "authorizationURL": "https://github.com/login/oauth/authorize", "tokenURL": "https://github.com/login/oauth/access_token", "userProfileURL": "https://api.github.com/user", "userEmailURL": "https://api.github.com/user/emails", "attributeMap": {"email": "_extractPrimaryEmail", "name": "name", "avatar": "avatar_url"}}, "wecom": {"enabled": "${WECOM_CORP_ID:true}", "type": "oauth2", "displayName": "企业微信", "icon": "wechat", "clientId": "${WECOM_CORP_ID}", "clientSecret": "${WECOM_SECRET}", "agentId": "${WECOM_AGENT_ID}", "callbackURL": "${WECOM_CALLBACK_URL}", "scope": ["snsapi_base"], "authorizationURL": "https://open.weixin.qq.com/connect/oauth2/authorize", "tokenURL": "https://qyapi.weixin.cgi/cgi-bin/gettoken", "userInfoURL": "https://qyapi.weixin.cgi/cgi-bin/user/getuserinfo", "attributeMap": {"email": "_deriveFromUserId", "name": "name", "avatar": "avatar"}}, "dingtalk": {"enabled": "${DINGTALK_APP_KEY:true}", "type": "oauth2", "displayName": "钉钉", "icon": "dingtalk", "clientId": "${DINGTALK_APP_KEY}", "clientSecret": "${DINGTALK_APP_SECRET}", "callbackURL": "${DINGTALK_CALLBACK_URL}", "scope": ["openid", "corpid"], "authorizationURL": "https://oapi.dingtalk.com/connect/qrconnect", "tokenURL": "https://oapi.dingtalk.com/v1.0/oauth2/userAccessToken", "userInfoURL": "https://oapi.dingtalk.com/topapi/v2/user/get", "attributeMap": {"email": "unionid", "name": "nick", "avatar": "avatarUrl"}}, "keycloak": {"enabled": "${KEYCLOAK_AUTH_SERVER_URL:true}", "type": "oidc", "displayName": "Keycloak", "icon": "keycloak", "realm": "${KEYCLOAK_REALM}", "authServerURL": "${KEYCLOAK_AUTH_SERVER_URL}", "clientId": "${KEYCLOAK_CLIENT_ID}", "clientSecret": "${KEYCLOAK_CLIENT_SECRET}", "callbackURL": "${KEYCLOAK_CALLBACK_URL}", "scope": ["openid", "profile", "email"], "attributeMap": {"email": "email", "name": "preferred_username", "avatar": "picture"}, "roleMapping": {"rules": [{"groupPattern": "^/admins$", "role": "ADMIN"}, {"groupPattern": "^/viewers$", "role": "VIEWER"}], "defaultRole": "USER"}}, "auth0": {"enabled": "${AUTH0_DOMAIN:true}", "type": "oidc", "displayName": "Auth0", "icon": "auth0", "domain": "${AUTH0_DOMAIN}", "clientId": "${AUTH0_CLIENT_ID}", "clientSecret": "${AUTH0_CLIENT_SECRET}", "callbackURL": "${AUTH0_CALLBACK_URL}", "scope": ["openid", "profile", "email"], "attributeMap": {"email": "email", "name": "name", "avatar": "picture"}}, "ldap": {"enabled": "${LDAP_URL:true}", "type": "ldap", "displayName": "Active Directory", "icon": "windows", "url": "${LDAP_URL}", "bindDN": "${LDAP_BIND_DN}", "bindCredentials": "${LDAP_BIND_PASSWORD}", "searchBase": "${LDAP_SEARCH_BASE}", "searchFilter": "${LDAP_SEARCH_FILTER}", "searchAttributes": ["mail", "displayName", "memberOf", "thumbnailPhoto"], "tlsOptions": {"ca": "${LDAP_TLS_CA_CERTS}"}, "attributeMap": {"email": "mail", "name": "displayName", "avatar": "thumbnailPhoto"}, "roleMapping": {"rules": [{