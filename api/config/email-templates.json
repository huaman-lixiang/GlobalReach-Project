{"templates": {"welcome": {"subject": "欢迎加入 GlobalReach", "body": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><style>body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;max-width:600px;margin:0 auto;padding:20px;color:#333;line-height:1.6}.header{background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:#fff;padding:30px 20px;text-align:center;border-radius:10px 10px 0 0}.content{padding:25px 20px}.footer{border-top:1px solid #eee;padding-top:15px;font-size:12px;color:#999;text-align:center}</style></head><body><div class=\"header\"><h1 style=\"margin:0\">欢迎加入 GlobalReach</h1></div><div class=\"content\"><p>尊敬的 {{client.firstName}} {{client.lastName}}，</p><p>感谢您注册 GlobalReach 企业级邮件营销平台！您的账号已成功创建。</p><p>通过我们的平台，您可以：</p><ul><li>管理多个邮件发送账号（Gmail/Outlook/QQ/163等）</li><li>创建和执行精准的邮件营销活动</li><li>实时追踪邮件送达率和打开率</li><li>使用智能模板引擎个性化每封邮件</li></ul><p>如有任何问题，请随时联系我们的支持团队。</p><p>祝好，<br>{{user.name}}<br>{{user.company || "GlobalReach Team"}}</p></div><div class=\"footer\"><p>此邮件由 GlobalReach V2.0 系统自动发送 | <a href=\"{{unsubscribeUrl}}\">取消订阅</a></p></div></body></html>", "description": "新用户欢迎邮件", "category": "transactional"}, "campaign_complete": {"subject": "营销活动已完成 — {{campaign.name}}", "body": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><style>body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;max-width:600px;margin:0 auto;padding:20px;color:#333;line-height:1.6}.card{background:#f9f9f9;border-radius:10px;padding:25px;margin:15px 0}.stat-row{display:flex;justify-content:space-between;margin:8px 0}.stat-label{color:#666}.stat-value{font-weight:600;color:#1890ff}.success{color:#52c41a}.failed{color:#ff4d4f}</style></head><body><div class=\"card\"><h2 style=\"margin-top:0;color:#1890ff\">📊 营销活动完成报告</h2><p>您的营销活动 <strong>{{campaign.name}}</strong> 已完成发送。</p><div class=\"stat-row\"><span class=\"stat-label\">总发送数</span><span class=\"stat-value\">{{stats.total}}</span></div><div class=\"stat-row\"><span class=\"stat-label\">成功送达</span><span class=\"stat-value success\">{{stats.sent}}</span></div><div class=\"stat-row\"><span class=\"stat-label\">发送失败</span><span class=\"stat-value failed\">{{stats.failed}}</span></div><div class=\"stat-row\"><span class=\"stat-label\">成功率</span><span class=\"stat-value\">{{stats.successRate}}%</span></div><div class=\"stat-row\"><span class=\"stat-label\">完成时间</span><span class=\"stat-label\">{{formatDate stats.completedAt "YYYY-MM-DD HH:mm"}}</span></div><p>登录 <a href=\"{{dashboardUrl}}\">GlobalReach 控制台</a> 查看详细报告。</p></div></body></html>", "description": "营销活动完成通知", "category": "notification"}, "alert": {"subject": "[告警] GlobalReach 系统通知 — {{alertType || "系统异常"}}", "body": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><style>body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;max-width:550px;margin:0 auto;padding:20px;color:#333;line-height:1.6}.alert-card{border-left:4px solid #ff4d4f;background:#fff2f0;border-radius:0 8px 8px 0;padding:20px;margin:15px 0}.warn-card{border-left:4px solid #fa8c16;background:#fff7e6;border-radius:0 8px 8px 0;padding:20px;margin:15px 0}.info-card{border-left:4px solid #1890ff;background:#e6f7ff;border-radius:0 8px 8px 0;padding:20px;margin:15px 0}</style></head><body><div class=\"{{#if isWarning}}warn-card{{else if isInfo}}info-card{{else}}alert-card{{/if}}\"><h2 style=\"margin-top:0\">⚠️ {{alertType || "系统告警"}}</h2><p>{{{alertMessage}}}</p>{{#if alertDetails}}<pre style=\"background:#f5f5f5;padding:12px;border-radius:6px;font-size:13px;overflow-x:auto\">{{{alertDetails}}}</pre>{{/if}}<p style=\"color:#888;font-size:14px;margin-top:15px\">告警时间：{{formatDate now "YYYY-MM-DD HH:mm:ss"}}<br>服务节点：{{serverNode || "unknown"}}</p></div></body></html>", "description": "系统告警通知", "category": "alert"}, "weekly_report": {"subject": "{{user.company || "GlobalReach"}} 周报 — {{formatDate weekStart "YYYY年MM月DD日"}} 至 {{formatDate weekEnd "YYYY年MM月DD日"}}", "body": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><style>body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;max-width:650px;margin:0 auto;padding:20px;color:#333;line-height:1.7}.banner{background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:#fff;padding:35px 20px;text-align:center;border-radius:10px 10px 0 0}.banner h1{margin:0;font-size:22px}.section{padding:20px 0;border-bottom:1px solid #f0f0f0}.metric-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:15px 0}.metric-box{background:#fafafa;border-radius:8px;padding:16px;text-align:center}.metric-value{font-size:24px;font-weight:700;color:#1890ff}.metric-label{font-size:12px;color:#888;margin-top:4px}.footer{background:#f5f5f5;padding:18px;text-align:center;font-size:13px;color:#888;border-radius:0 0 10px 10px}</style></head><body><div class=\"banner\"><h1>📈 {{user.company || "GlobalReach"}} 营销周报</h1><p>{{formatDate weekStart "YYYY/MM/DD"}} — {{formatDate weekEnd "YYYY/MM/DD"}}</p></div><div class=\"section\"><h3 style=\"color:#1890ff;margin-bottom:12px\">核心指标</h3><div class=\"metric-grid\"><div class=\"metric-box\"><div class=\"metric-value\">{{metrics.totalSent || 0}}</div><div class=\"metric-label\">本周发送总数</div></div><div class=\"metric-box\"><div class=\"metric-value\" style=\"color:#52c41a\">{{metrics.deliveredRate || 0}}%</div><div class=\"metric-label\">送达率</div></div><div class=\"metric-box\"><div class=\"metric-value\" style=\"color:#722ed1\">{{metrics.openRate || 0}}%</div><div class=\"metric-label\">打开率</div></div><div class=\"metric-box\"><div class=\"metric-value\" style=\"color:#fa8c16\">{{metrics.clickRate || 0}}%</div><div class=\"metric-label\">点击率</div></div></div></div><div class=\"section\"><h3 style=\"color:#1890ff;margin-bottom:12px\">活动概览</h3>{{#each campaigns}}<p><strong>{{this.name}}</strong>: {{this.status}} ({{this.sentCount}} 封)</p>{{/each}}{{#unless campaigns}}<p style=\"color:#999\">本周暂无活动数据</p>{{/unless}}</div><div class=\"footer\"><p>此报告由 GlobalReach V2.0 自动生成 | <a href=\"{{dashboardUrl}}\">查看详情</a></p></div></body></html>", "description": "每周运营报告", "category": "report"}}, "providers": {"qq": {"host": "smtp.qq.com", "port": 465, "secure": true, "from": "${SMTP_QQ_FROM:-1390885333@qq.com}", "maxPerDay": 200, "maxPerSecond": 3, "description": "QQ邮箱 SMTP（当前主用）"}, "gmail": {"host": "smtp.gmail.com", "port": 587, "secure": false, "from": "${SMTP_GMAIL_FROM:-}", "maxPerDay": 500, "maxPerSecond": 10, "description": "Gmail SMTP（需开启应用专用密码）"}, "outlook": {"host": "smtp.office365.com", "port": 587, "secure": false, "from": "${SMTP_OUTLOOK_FROM:-}", "maxPerDay": 300, "maxPerSecond": 10, "description": "Outlook/Office365 SMTP"}, "163": {"host": "smtp.163.com", "port": 465, "secure": true, "from": "${SMTP_163_FROM:-}", "maxPerDay": 200, "maxPerSecond": 3, "description": "网易163邮箱 SMTP"}, "custom": {"host": "${SMTP_CUSTOM_HOST:-}", "port": ${SMTP_CUSTOM_PORT:-587}, "secure": ${SMTP_CUSTOM_SECURE:-false}, "from": "${SMTP_CUSTOM_FROM:-}", "maxPerDay": ${SMTP_CUSTOM_MAX_PER_DAY:-1000}, "maxPerSecond": ${SMTP_CUSTOM_MAX_PER_SECOND:-10}, "description": "自定义 SMTP 服务器"}}, "queueConfig": {"maxConcurrency": 5, "rateLimitPerSecond": 3, "maxRetries": 3, "retryBaseDelayMs": 1000, "connectionTimeoutMs": 10000, "sendTimeoutMs": 30000, "roundRobinEnabled": true, "autoFailoverEnabled": true}, "trackingConfig": {"enabled": true, "retainDays": 90, "logLevel": "info"}}