# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=*

# JWT Configuration
JWT_SECRET=globalreach-enterprise-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Database (Future)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=globalreach
# DB_USER=admin
# DB_PASSWORD=

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
