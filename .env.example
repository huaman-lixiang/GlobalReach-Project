# GlobalReach V2.0 Docker Environment Configuration
# Copy this file to .env and modify values for your environment

# Application Settings
NODE_ENV=production

# API Server
API_PORT=3000

# Security - CHANGE THESE IN PRODUCTION!
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=24h

# Database (SQLite)
DB_PATH=/app/data/globalreach.db

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Nginx Ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# SSL Certificate (Optional - for HTTPS)
SSL_CERTIFICATE_PATH=/etc/nginx/ssl/cert.pem
SSL_CERTIFICATE_KEY_PATH=/etc/nginx/ssl/key.pem

# Logging
LOG_LEVEL=info
